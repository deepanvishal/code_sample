# ApplyPilot DB — read-only, never write to this file
APPLYPILOT_DB=~/.applypilot/applypilot.db

# pilot-intel data directory (Qdrant storage, SQLite cache)
PILOT_INTEL_DIR=~/.pilot-intel

# LLM — set one of: ANTHROPIC_API_KEY, OPENAI_API_KEY, or LLM_URL for local Ollama
ANTHROPIC_API_KEY=...
OPENAI_API_KEY=...
LLM_URL=http://localhost:11434/v1
LLM_MODEL=llama3.1:8b

# Router model — fast cheap model used only for question classification
ROUTER_MODEL=phi4
ROUTER_URL=http://localhost:11434/v1

# SQLCoder — text-to-SQL model served via Ollama
SQLCODER_URL=http://localhost:11434/v1
SQLCODER_MODEL=sqlcoder-7b-2-q4

# LangSmith tracing (optional but recommended)
# Get key from smith.langchain.com
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=pilot-intel
LANGSMITH_TRACING=false

# Qdrant — local path is derived from PILOT_INTEL_DIR/qdrant automatically
# Uncomment QDRANT_URL to use server mode instead of local
# QDRANT_URL=http://localhost:6333
